# Mobile app (Expo) — Supabase Dashboard → Project Settings → API
#
# EXPO_PUBLIC_SUPABASE_URL = API URL WITHOUT /rest/v1
#   ✅ https://your-project-ref.supabase.co
#   ❌ https://your-project-ref.supabase.co/rest/v1/
#
# EXPO_PUBLIC_SUPABASE_ANON_KEY = Publishable key (NOT secret key)

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here
